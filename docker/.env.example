###################################################################################
# Global
###################################################################################
TZ=Europe/Stockholm
PUID=99
PGID=100

###################################################################################
# Core Networking / Domains
###################################################################################
BASE_DOMAIN=edvardsson.dev
TAILNET_DOMAIN=tailc229ea.ts.net
ACME_EMAIL=jakob@edvardsson.dev
CLOUDFLARE_API_TOKEN=replace-me

###################################################################################
# Shared Paths
###################################################################################
APPDATA_ROOT=/mnt/user/appdata
MEDIA_ROOT=/mnt/user/data/media
DOWNLOADS_ROOT=/mnt/user/data/downloads
CZKAWKA_STORAGE_ROOT=/mnt/user

###################################################################################
# Docker DNS
###################################################################################
DOCKER_DNS_1=100.100.100.100
DOCKER_DNS_2=1.1.1.1
DOCKER_DNS_3=1.0.0.1

###################################################################################
# Published Ports
###################################################################################
IMMICH_PUBLISHED_PORT=2283
GRAFANA_PUBLISHED_PORT=3000
PROMETHEUS_PUBLISHED_PORT=9090
HEALTHCHECKS_PUBLISHED_PORT=8000
HOMEPAGE_PUBLISHED_PORT=3001
CZKAWKA_PUBLISHED_PORT=5800
WUD_PUBLISHED_PORT=3002
QBITTORRENT_PUBLISHED_PORT=8080
QBITTORRENT_TORRENTING_PORT=6881

###################################################################################
# VPN / qBittorrent
###################################################################################
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=replace-me
SERVER_COUNTRIES=Sweden

###################################################################################
# Immich
###################################################################################
# The location where your uploaded files are stored
UPLOAD_LOCATION=/mnt/user/immich/library
# The location where your database files are stored. Network shares are not supported for the database
DB_DATA_LOCATION=/mnt/user/appdata/immich/postgres
TZ=Europe/Stockholm
# The Immich version to use. You can pin this to a specific version like "v2.1.0"
IMMICH_VERSION=v2

# Connection secret for postgres. You should change it to a random password
# Please use only the characters `A-Za-z0-9`, without special characters or spaces
DB_PASSWORD=postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

###################################################################################
# Grafana
###################################################################################
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-me
GRAFANA_DISCORD_WEBHOOK=https://discord.com/api/webhooks/replace-me/replace-me

###################################################################################
# Healthchecks
###################################################################################
HEALTHCHECKS_SECRET_KEY=replace-me

###################################################################################
# Authentik
###################################################################################
AUTHENTIK_TAG=2026.2.1
AUTHENTIK_SECRET_KEY=replace-me
AUTHENTIK_BOOTSTRAP_EMAIL=admin@edvardsson.dev
AUTHENTIK_BOOTSTRAP_PASSWORD=replace-me
PG_DB=authentik
PG_USER=authentik
PG_PASS=replace-me

###################################################################################
# Authentik Email / SMTP
###################################################################################
AUTHENTIK_EMAIL__HOST=smtp.protonmail.ch
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USERNAME=your-address@yourdomain.com
AUTHENTIK_EMAIL__PASSWORD=your-smtp-token
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__TIMEOUT=10
AUTHENTIK_EMAIL__FROM=your-address@yourdomain.com

###################################################################################
# WUD / Authentik OIDC
###################################################################################
WUD_AUTH_OIDC_AUTHENTIK_CLIENTID=replace-me
WUD_AUTH_OIDC_AUTHENTIK_CLIENTSECRET=replace-me
WUD_AUTH_OIDC_AUTHENTIK_DISCOVERY=https://authentik.${BASE_DOMAIN}/application/o/wud_oidc/.well-known/openid-configuration
WUD_AUTH_OIDC_AUTHENTIK_REDIRECT=true

###################################################################################
# Booli
###################################################################################
BOOLI_IMAGE_TAG=latest
BOOLI_WEB_PUBLISHED_PORT=3010
BOOLI_API_PUBLISHED_PORT=8085
BOOLI_NEO4J_HTTP_PUBLISHED_PORT=7474
BOOLI_NEO4J_BOLT_PUBLISHED_PORT=7687
BOOLI_NEO4J_URI=bolt://booli-neo4j:7687
BOOLI_NEO4J_USERNAME=neo4j
BOOLI_NEO4J_PASSWORD=replace-me
BOOLI_NEO4J_DATABASE=neo4j
BOOLI_SCRAPE_INTERVAL_SECONDS=3600
BOOLI_STATUS_CHECK_INTERVAL_SECONDS=21600
BOOLI_SCRAPE_SEARCH_URL="https://www.booli.se/sok/till-salu?areaIds=1007277&objectType=Villa"
BOOLI_SOLD_HISTORY_SEARCH_URL="https://www.booli.se/sok/slutpriser?areaIds=1007277&objectType=Villa"
BOOLI_IMAGE_DOWNLOAD_ENABLED=true
BOOLI_IMAGE_DOWNLOAD_TIMEOUT_SECONDS=20
BOOLI_IMAGE_DOWNLOAD_RETRIES=2
BOOLI_IMAGE_DOWNLOAD_VERBOSE=false
