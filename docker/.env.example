###################################################################################
# Global
###################################################################################
TZ=Europe/Stockholm
PUID=99
PGID=100

###################################################################################
# Core Networking / Domains
###################################################################################
BASE_DOMAIN=edvardsson.dev
TAILNET_DOMAIN=tailc229ea.ts.net
ACME_EMAIL=jakob@edvardsson.dev
CLOUDFLARE_API_TOKEN=replace-me

###################################################################################
# Shared Paths
###################################################################################
APPDATA_ROOT=/mnt/user/appdata
MEDIA_ROOT=/mnt/user/data/media
DOWNLOADS_ROOT=/mnt/user/data/downloads

###################################################################################
# Published Ports
###################################################################################
JELLYFIN_PUBLISHED_PORT=8096
JELLYSEERR_PUBLISHED_PORT=5055
PROWLARR_PUBLISHED_PORT=9696
RADARR_PUBLISHED_PORT=7878
SONARR_PUBLISHED_PORT=8989
BAZARR_PUBLISHED_PORT=6767
DELUGE_WEB_PUBLISHED_PORT=8112
IMMICH_PUBLISHED_PORT=2283
GRAFANA_PUBLISHED_PORT=3000
PROMETHEUS_PUBLISHED_PORT=9090
HEALTHCHECKS_PUBLISHED_PORT=8000
HOMEPAGE_PUBLISHED_PORT=3001

###################################################################################
# Deluge / VPN
###################################################################################
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=replace-me
WIREGUARD_ADDRESSES=10.2.0.2/32
WIREGUARD_PUBLIC_KEY=replace-me
WIREGUARD_ENDPOINT_IP=replace-me
WIREGUARD_ENDPOINT_PORT=51820
WIREGUARD_PRESHARED_KEY=
VPN_DNS_ADDRESS=10.2.0.1

DELUGE_PASSWORD=replace-me

###################################################################################
# Immich
###################################################################################
# The location where your uploaded files are stored
UPLOAD_LOCATION=/mnt/user/immich/library
# The location where your database files are stored. Network shares are not supported for the database
DB_DATA_LOCATION=/mnt/user/appdata/immich/postgres
TZ=Europe/Stockholm
# The Immich version to use. You can pin this to a specific version like "v2.1.0"
IMMICH_VERSION=v2

# Connection secret for postgres. You should change it to a random password
# Please use only the characters `A-Za-z0-9`, without special characters or spaces
DB_PASSWORD=postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

###################################################################################
# Grafana
###################################################################################
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-me

###################################################################################
# Healthchecks
###################################################################################
HEALTHCHECKS_SECRET_KEY=replace-me

###################################################################################
# Authentik
###################################################################################
AUTHENTIK_TAG=2026.2.1
AUTHENTIK_SECRET_KEY=replace-me
AUTHENTIK_BOOTSTRAP_EMAIL=admin@edvardsson.dev
AUTHENTIK_BOOTSTRAP_PASSWORD=replace-me
PG_DB=authentik
PG_USER=authentik
PG_PASS=replace-me

###################################################################################
# Authentik Email / SMTP
###################################################################################
AUTHENTIK_EMAIL__HOST=smtp.protonmail.ch
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USERNAME=your-address@yourdomain.com
AUTHENTIK_EMAIL__PASSWORD=your-smtp-token
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__TIMEOUT=10
AUTHENTIK_EMAIL__FROM=your-address@yourdomain.com
