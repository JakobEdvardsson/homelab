{
	email {$ACME_EMAIL}
}

*.{$BASE_DOMAIN} {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
		resolvers 1.1.1.1
	}

	@homepage host homepage.{$BASE_DOMAIN}
	handle @homepage {
		reverse_proxy homepage:3000
	}

	@unraid host unraid.{$BASE_DOMAIN}
	handle @unraid {
		reverse_proxy https://tower:444 {
			transport http {
				tls_insecure_skip_verify
			}
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Port {server_port}
		}
	}

	@jellyfin host jellyfin.{$BASE_DOMAIN}
	handle @jellyfin {
		reverse_proxy jellyfin:8096
	}

	@jellyseerr host jellyseerr.{$BASE_DOMAIN}
	handle @jellyseerr {
		reverse_proxy jellyseerr:5055
	}

	@prowlarr host prowlarr.{$BASE_DOMAIN}
	handle @prowlarr {
		reverse_proxy prowlarr:9696
	}

	@radarr host radarr.{$BASE_DOMAIN}
	handle @radarr {
		reverse_proxy radarr:7878
	}

	@sonarr host sonarr.{$BASE_DOMAIN}
	handle @sonarr {
		reverse_proxy sonarr:8989
	}

	@bazarr host bazarr.{$BASE_DOMAIN}
	handle @bazarr {
		reverse_proxy bazarr:6767
	}

	@deluge host deluge.{$BASE_DOMAIN}
	handle @deluge {
		reverse_proxy gluetun:8112
	}

	@immich host immich.{$BASE_DOMAIN}
	handle @immich {
		reverse_proxy immich_server:2283
	}

	@grafana host grafana.{$BASE_DOMAIN}
	handle @grafana {
		reverse_proxy grafana:3000
	}

	@prometheus host prometheus.{$BASE_DOMAIN}
	handle @prometheus {
		reverse_proxy prometheus:9090
	}

	@healthchecks host healthchecks.{$BASE_DOMAIN}
	handle @healthchecks {
		reverse_proxy healthchecks:8000
	}

	handle {
		redir https://homepage.{$BASE_DOMAIN}{uri} permanent
	}
}
